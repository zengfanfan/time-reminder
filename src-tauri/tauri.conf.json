{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeVeil",
  "version": "0.1.0",
  "identifier": "com.timeveil.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimeVeil",
        "width": 520,
        "height": 640,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "url": "/overlay",
        "title": "",
        "visible": false,
        "fullscreen": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "focus": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "TimeVeil"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
